{
  "name": "confirmation-saints-video",
  "version": "0.1.0",
  "private": true,
  "description": "Remotion promotional videos for the Confirmation Saints app",
  "scripts": {
    "start": "remotion studio",
    "build": "remotion render ConfirmationSaintsPromo out/ConfirmationSaintsPromo.mp4 --codec=h264",
    "render": "remotion render ConfirmationSaintsPromo out/ConfirmationSaintsPromo.mp4 --codec=h264",
    "render:facebook": "remotion render ConfirmationSaintsPromo4x5 out/ConfirmationSaintsPromo-Facebook.mp4 --codec=h264",
    "upgrade": "remotion upgrade"
  },
  "dependencies": {
    "@remotion/bundler": "4.0.451",
    "@remotion/cli": "4.0.451",
    "@remotion/google-fonts": "4.0.451",
    "@remotion/renderer": "4.0.451",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "remotion": "4.0.451"
  },
  "devDependencies": {
    "@types/react": "19.0.0",
    "typescript": "5.8.3"
  }
}
