<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Base Material theme used only for the pre-Compose launch window. Real
      theming (colors, typography) lives in Kotlin: see
      com.yortch.confirmationsaints.ui.theme.ConfirmationSaintsTheme.
    -->
    <style name="Theme.ConfirmationSaints" parent="android:Theme.Material.Light.NoActionBar" />

    <!--
      AndroidX SplashScreen (androidx.core:core-splashscreen) — compatible
      Android 6+; Android 12+ uses the system splash API automatically.
      Uses dedicated splash icon (ic_splash) which is full-bleed without
      adaptive icon padding, so the logo appears complete on the splash screen.
    -->
    <style name="Theme.ConfirmationSaints.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_background</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_splash</item>
        <item name="postSplashScreenTheme">@style/Theme.ConfirmationSaints</item>
    </style>
</resources>
