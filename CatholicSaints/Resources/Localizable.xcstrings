    "confirmation_explanation" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confirmation is one of the seven sacraments of the Catholic Church. It is the sacrament through which the Holy Spirit strengthens the faith of those who have already been baptized. During Confirmation, candidates affirm their faith and receive the gifts of the Holy Spirit to help them live as faithful witnesses of Christ."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La Confirmación es uno de los siete sacramentos de la Iglesia Católica. Es el sacramento mediante el cual el Espíritu Santo fortalece la fe de quienes ya han sido bautizados. Durante la Confirmación, los candidatos afirman su fe y reciben los dones del Espíritu Santo para ayudarles a vivir como testigos fieles de Cristo."
          }
        }
      }
    },
    "choosing_saint_explanation" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A beautiful tradition in preparing for Confirmation is choosing a patron saint. This saint becomes your spiritual companion — someone whose life inspires you and whose intercession you seek. Choose a saint whose story resonates with you, whose virtues you admire, or whose interests align with yours."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una hermosa tradición en la preparación para la Confirmación es elegir un santo patrón. Este santo se convierte en tu compañero espiritual — alguien cuya vida te inspira y cuya intercesión buscas. Elige un santo cuya historia resuene contigo, cuyas virtudes admires o cuyos intereses se alineen con los tuyos."
          }
        }
      }
    },
    "app_usage_guide" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Browse saints in the Saints tab or use Search to filter by interests, age, country, and more. Tap on any saint to read their story. Take your time — finding the right patron saint is a personal and meaningful journey."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Explora los santos en la pestaña Santos o usa Buscar para filtrar por intereses, edad, país y más. Toca cualquier santo para leer su historia. Tómate tu tiempo — encontrar el santo patrón adecuado es un viaje personal y significativo."
          }
        }
      }
    },
    "sources_attribution" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Saint information in this app is sourced from Loyola Press, Catholic News Agency, Franciscan Media, and other trusted Catholic resources. Each saint entry includes specific source attribution. Images are used with attribution where available."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La información sobre los santos en esta app proviene de Loyola Press, Catholic News Agency, Franciscan Media y otros recursos católicos confiables. Cada entrada de santo incluye la atribución específica de la fuente. Las imágenes se utilizan con atribución cuando están disponibles."
          }
        }
      }
    },
